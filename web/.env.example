# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Base URL of the Node.js API server (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Shopify store domain to load in local dev
# Must match a store already seeded in the database
NEXT_PUBLIC_SHOP=your-store.myshopify.com

# Auth is handled via HttpOnly session cookie issued after Shopify OAuth install.
# No bearer token needed.
